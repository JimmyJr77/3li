generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- App accounts (username / password) ---

model AppUser {
  id           String       @id @default(cuid())
  /// Lowercase login id (unique).
  username     String       @unique
  email        String       @unique
  /// US mobile stored as ###-###-####; optional only for legacy rows before phone was required.
  phone        String?      @unique
  passwordHash String
  firstName    String?
  lastName     String?
  displayName  String?
  /// "user" | "admin"
  role         String       @default("user")
  brands       Brand[]
  brandMemberships BrandMember[]
  brandMembersInvited BrandMember[] @relation("BrandMemberInvitedBy")
  brandInvitesSent BrandInvite[] @relation("BrandInviteInvitedBy")
  brandInvitesConsumed BrandInvite[] @relation("BrandInviteConsumedBy")
  sessions     AppSession[]
  /// Task board events attributed to this login (Activity Tracker).
  authoredTaskActivities Activity[] @relation("TaskActivityActor")
  tasksCreated           Task[]     @relation("TaskCreatedBy")
  tasksAssigned          Task[]     @relation("TaskAssignee")
  ticketAssignmentEvents TicketAssignmentEvent[]
  subBoardPreferences    SubBoardPreference[]
  /// Custom project board column layouts; not shared with other logins.
  customBoardTemplates CustomBoardTemplate[]
  /// Reusable ticket labels (name + color) scoped by brand; shown on tasks for this user.
  userBrandTicketLabels UserBrandTicketLabel[]
  boardUserPreferences  BoardUserPreference[]
  workspaceUserPreferences WorkspaceUserPreference[]
  /// Ticket comments authored by this login (nullable on legacy rows).
  taskCommentsAuthored  Comment[]    @relation("TaskCommentAuthor")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model AppSession {
  id        String   @id @default(cuid())
  userId    String
  user      AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// sha256 hex of the opaque cookie token (never store raw token).
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// --- Brainstorm (existing product area) ---

model Project {
  id        String              @id @default(cuid())
  name      String              @default("Workspace")
  /// Brainstorm + consulting chat + RAG scope: one project per brand workspace.
  workspaceId String?           @unique
  workspace   Workspace?      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sessions  BrainstormSession[]
  chatThreads ChatThread[]
  documents   ChatDocument[]
  createdAt DateTime            @default(now())
}

model BrainstormSession {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title     String   @default("Brainstorm")
  nodes     IdeaNode[]
  edges     IdeaEdge[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model IdeaNode {
  id          String            @id @default(cuid())
  sessionId   String
  session     BrainstormSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  /// "idea" | "shape" | "text" | "hierarchy" — idea rows use columns below; others use `payload` + title as label.
  kind        String            @default("idea")
  /// Type-specific fields (parentId, html, variant, etc.) for non-idea nodes.
  payload     Json?
  positionX   Float
  positionY   Float
  title       String
  description String            @default("")
  tags        String[]
  status      String            @default("idea")
  priority    String            @default("medium")
  tasks       Task[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model IdeaEdge {
  id        String            @id @default(cuid())
  sessionId String
  session   BrainstormSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sourceId  String
  targetId  String
  /// "solid" | "solid_bold" | "dotted"
  lineStyle String            @default("solid")
  /// Optional caption shown on the link in the canvas.
  label           String      @default("")
  /// React Flow handle ids (e.g. out/in for tree, lateral-* for side links).
  sourceHandle    String?
  targetHandle    String?
}

// --- TaskFoundry: brand → workspace (ecosystem) → project space → board → lists → tasks ---

/// Client or engagement: one brand kit, one sidebar row in “My brands”.
model Brand {
  id           String      @id @default(cuid())
  /// When set, this brand (and its workspace) belongs to that account. Null = legacy rows reassigned on seed.
  ownerUserId  String?
  ownerUser    AppUser?    @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)
  /// Canonical brand name (Settings, “My brands” list). Not the workspace chrome title — that is `Workspace.name`.
  name         String      @default("Brand")
  /// Company/brand identity kit for AI context (JSON). One kit per brand.
  brandProfile Json?
  /// Shared team methodology for LLM context; overrides user context on conflict (see context ladder).
  teamContextInstructions String? @db.Text
  /// Sort order among non-archived brands (sidebar / settings).
  position     Int         @default(0)
  /// Shareable token for self-join as a team member; owner can rotate without changing `id`.
  joinKey      String      @unique
  archivedAt   DateTime?
  workspaces   Workspace[]
  members      BrandMember[]
  invites      BrandInvite[]
  userBrandTicketLabels UserBrandTicketLabel[]
  /// Next sequential ticket number to assign for this brand (see `Task.brandTicketNumber`).
  nextTicketNumber   Int         @default(1)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([archivedAt])
  @@index([ownerUserId])
}

/// Additional accounts that can use a brand workspace (owner remains on `Brand.ownerUserId`).
model BrandMember {
  id               String   @id @default(cuid())
  brandId          String
  brand            Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  userId           String
  user             AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  invitedByUserId  String?
  invitedBy        AppUser? @relation("BrandMemberInvitedBy", fields: [invitedByUserId], references: [id], onDelete: SetNull)
  createdAt        DateTime @default(now())

  @@unique([brandId, userId])
  @@index([userId])
  @@index([brandId])
}

/// Pending email invite to join a brand team (token shown in invite link only).
model BrandInvite {
  id               String    @id @default(cuid())
  brandId          String
  brand            Brand     @relation(fields: [brandId], references: [id], onDelete: Cascade)
  /// Normalized lowercase email the invitee must sign up or sign in with.
  email            String
  tokenHash        String    @unique
  invitedByUserId  String
  invitedBy        AppUser   @relation("BrandInviteInvitedBy", fields: [invitedByUserId], references: [id], onDelete: Cascade)
  expiresAt        DateTime
  consumedAt       DateTime?
  consumedByUserId String?
  consumedBy       AppUser?  @relation("BrandInviteConsumedBy", fields: [consumedByUserId], references: [id], onDelete: SetNull)
  createdAt        DateTime  @default(now())

  @@index([brandId])
  @@index([email])
}

/// One ecosystem per brand (notes, notebooks, activity, etc.). Boards live under ProjectSpaces inside this row.
model Workspace {
  id                   String                 @id @default(cuid())
  /// Label for this ecosystem (e.g. shown in admin); brand display name comes from Brand Center kit.
  name                 String
  /// Individual operator preferences for LLM context (Consultant Agent); team instructions override when both apply.
  userContextInstructions String? @db.Text
  brandId              String                 @unique
  brand                Brand                  @relation(fields: [brandId], references: [id], onDelete: Cascade)
  archivedAt           DateTime?
  projectSpaces        ProjectSpace[]
  chatThreads          ChatThread[]
  notesFolders         NotesFolder[]
  notes                Note[]
  noteTags             NoteTag[]
  customBoardTemplates CustomBoardTemplate[]
  brainstormProject    Project?
  routingHolds         RoutingHold[]
  agentSessions        AgentSession[]
  userPreferences      WorkspaceUserPreference[]
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  @@index([archivedAt])
}

/// Per-user UI preferences for a brand workspace (Ticket Tracker, etc.).
model WorkspaceUserPreference {
  id                         String    @id @default(cuid())
  userId                     String
  user                       AppUser   @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId              String
  workspace                  Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  /// When true, Ticket Tracker colors each ticket’s border by its project board accent color.
  ticketTrackerColorByBoard  Boolean   @default(false)
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  @@unique([userId, workspaceId])
  @@index([workspaceId])
}

/// User-visible history hub for workspace AI agents (except Consultant, which uses ChatThread).
model AgentSession {
  id          String              @id @default(cuid())
  workspaceId String
  workspace   Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  /// Hub key: project_manager | brand_rep | mail_clerk | brainstorm_ai | advisor_agents
  agentKind   String
  title       String              @default("Untitled")
  metadata    Json?
  archivedAt  DateTime?
  events      AgentSessionEvent[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([workspaceId, agentKind, updatedAt(sort: Desc)])
}

model AgentSessionEvent {
  id        String       @id @default(cuid())
  sessionId String
  session   AgentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  seq       Int
  type      String
  payload   Json?
  createdAt DateTime     @default(now())

  @@unique([sessionId, seq])
  @@index([sessionId])
}

/// Unresolved capture queued for later routing (holding pen / Mail Clerk handoff).
model RoutingHold {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  body        String    @db.Text
  meta        Json?
  /// pending | routed | dismissed
  status      String    @default("pending")
  /// rapid_router | mail_clerk_plan | mailroom | manual
  source      String    @default("manual")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([workspaceId])
  @@index([workspaceId, status])
}

/// Project space (delivery thread) within a brand workspace; project boards belong here.
model ProjectSpace {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  position    Int       @default(0)
  /// The first / primary project space for a workspace; cannot be archived or deleted. Name is user-editable.
  isDefault   Boolean   @default(false)
  /// Optional delivery-thread context for PM / settings (user-editable).
  purpose     String?   @db.Text
  archivedAt  DateTime?
  boards      Board[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([workspaceId])
  @@index([workspaceId, archivedAt])
  @@index([workspaceId, isDefault])
}

/// User-defined board column layouts (per signed-in user), merged with built-in templates in the UI.
model CustomBoardTemplate {
  id          String     @id @default(cuid())
  /// Owner; only this login sees the template. Null = legacy pre-per-user row (not listed in API).
  createdByUserId String?
  createdBy   AppUser?   @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)
  /// Legacy: previously workspace-scoped; kept for back-compat rows only.
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  name        String
  description String     @default("")
  /// [{ "title": string, "key": string | null }, ...]
  lists       Json
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([createdByUserId])
  @@index([workspaceId])
}

// --- Notebooks (folders + notes + tags; scoped to Workspace) ---

model NotesFolder {
  id              String        @id @default(cuid())
  workspaceId     String
  workspace       Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parentId        String?
  parent          NotesFolder?  @relation("NotesFolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children        NotesFolder[] @relation("NotesFolderTree")
  title           String
  position        Int           @default(0)
  /// Optional #RRGGBB tint for the notebook row in the browse columns UI.
  rowAccentColor  String?
  notes           Note[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([workspaceId])
  @@index([parentId])
}

model Note {
  id              String       @id @default(cuid())
  workspaceId     String
  workspace       Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  folderId        String?
  folder          NotesFolder?   @relation(fields: [folderId], references: [id], onDelete: SetNull)
  title           String         @default("Untitled")
  slug            String?
  contentJson     Json?
  previewText     String?        @db.Text
  position        Int            @default(0)
  /// Optional #RRGGBB tint for the note row in the browse columns UI.
  rowAccentColor  String?
  isPinned        Boolean        @default(false)
  isPublic        Boolean        @default(false)
  publicSlug      String?        @unique
  tags            NoteTag[]
  /// Board-scoped project labels (same `Label` rows as tickets) attached to this note.
  labels          NoteLabel[]
  /// Per-user brand ticket labels attached to this note.
  userBrandTicketLabels NoteUserBrandTicketLabel[]
  linksFrom       NoteLink[]     @relation("NoteLinkFrom")
  linksTo         NoteLink[]     @relation("NoteLinkTo")
  /// Optional provenance when created from Rapid Router / Mailroom-style capture.
  routingSource   String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([workspaceId])
  @@index([folderId])
  @@unique([workspaceId, slug])
}

model NoteTag {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  color       String    @default("#6366f1")
  notes       Note[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model NoteLink {
  id         String   @id @default(cuid())
  fromNoteId String
  toNoteId   String
  fromNote   Note     @relation("NoteLinkFrom", fields: [fromNoteId], references: [id], onDelete: Cascade)
  toNote     Note     @relation("NoteLinkTo", fields: [toNoteId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([fromNoteId, toNoteId])
  @@index([fromNoteId])
  @@index([toNoteId])
}

model Board {
  id             String       @id @default(cuid())
  projectSpaceId String
  projectSpace   ProjectSpace @relation(fields: [projectSpaceId], references: [id], onDelete: Cascade)
  name           String
  position       Int          @default(0)
  archivedAt     DateTime?
  /// Brand-wide accent for this project board (Ticket Tracker, card borders when enabled).
  accentColor    String       @default("#6366f1") @db.VarChar(32)
  lists          BoardList[]
  labels         Label[]
  userPreferences BoardUserPreference[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([projectSpaceId])
  @@index([projectSpaceId, archivedAt])
}

/// Per-user defaults for a project board (card color, lane visibility, checkbox default, hidden sub-boards).
model BoardUserPreference {
  id                             String          @id @default(cuid())
  userId                         String
  user                           AppUser         @relation(fields: [userId], references: [id], onDelete: Cascade)
  boardId                        String
  board                          Board           @relation(fields: [boardId], references: [id], onDelete: Cascade)
  defaultTicketCardColor         String?         @db.VarChar(32)
  defaultHiddenTrackerStatuses   TrackerStatus[]
  defaultCompleteCheckboxVisible Boolean         @default(true)
  /// standard | minimal — default for sub-boards until you open sub-board options (per-user).
  defaultCardFaceLayout          String          @default("standard") @db.VarChar(64)
  /// Per-user default “title + meta” fields on standard cards (`{}` = all on; see app `CARD_FACE_META_KEYS`).
  defaultCardFaceMeta            Json            @default("{}")
  /// Sub-board (`BoardList`) ids hidden from this user’s tab strip for this board.
  hiddenSubBoardIds              String[]
  /// When true, this user sees the project board accent as a colored border on ticket cards on this board.
  showBoardAccentBorder          Boolean         @default(true)
  createdAt                      DateTime        @default(now())
  updatedAt                      DateTime        @updatedAt

  @@unique([userId, boardId])
  @@index([boardId])
}

/// Project sub-board (horizontal swimlane on a project board); tickets live in fixed tracker columns within it.
model BoardList {
  id        String   @id @default(cuid())
  boardId   String
  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  title     String
  /// Legacy template key (backlog / in_progress / done) — optional; tracker status is on each ticket.
  key       String?
  position  Int      @default(0)
  tasks     Task[]
  preferences SubBoardPreference[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([boardId, key])
  @@index([boardId])
}

/// Per-user display preferences for a project sub-board.
model SubBoardPreference {
  id                    String          @id @default(cuid())
  userId                String
  user                  AppUser         @relation(fields: [userId], references: [id], onDelete: Cascade)
  subBoardId            String
  subBoard              BoardList       @relation(fields: [subBoardId], references: [id], onDelete: Cascade)
  ticketCardColor                    String?  @db.VarChar(32)
  /// standard | minimal — applies to all ticket cards on this sub-board for this user.
  cardFaceLayout                   String   @default("standard") @db.VarChar(64)
  /// Optional overrides for “title + meta” on standard cards; merged with board defaults.
  cardFaceMeta                     Json?
  /// When true, the done checkbox is shown on kanban cards unless a ticket overrides.
  completeCheckboxVisibleByDefault Boolean  @default(true)
  hiddenTrackerStatuses            TrackerStatus[]
  createdAt                        DateTime @default(now())
  updatedAt             DateTime        @updatedAt

  @@unique([userId, subBoardId])
  @@index([subBoardId])
}

enum TrackerStatus {
  FREE_SPACE
  CONTEXT
  BRAINSTORM
  BACKLOG
  IN_PROGRESS
  IN_REVIEW
  DONE
}

model Task {
  id           String    @id @default(cuid())
  subBoardId   String
  subBoard     BoardList @relation(fields: [subBoardId], references: [id], onDelete: Cascade)
  trackerStatus TrackerStatus @default(BACKLOG)
  title        String
  description  String    @default("")
  completed    Boolean   @default(false)
  order        Int       @default(0)
  priority     String    @default("none")
  archivedAt   DateTime?
  dueDate      DateTime?
  startDate    DateTime?
  ideaNodeId   String?
  ideaNode     IdeaNode? @relation(fields: [ideaNodeId], references: [id], onDelete: SetNull)
  chatThreadId String?
  chatThread   ChatThread? @relation(fields: [chatThreadId], references: [id], onDelete: SetNull)
  sourceMessageId String?
  /// Optional provenance: e.g. rapid_router, mailroom_plan (UI may show “from capture”).
  routingSource   String?
  createdByUserId String?
  createdBy       AppUser? @relation("TaskCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  assigneeUserId  String?
  assignee        AppUser? @relation("TaskAssignee", fields: [assigneeUserId], references: [id], onDelete: SetNull)
  /// Sequential per brand (1, 2, 3, …) for display; assigned at task creation.
  brandTicketNumber Int?
  lastAssignedAt  DateTime?
  /// @deprecated Per-sub-board `SubBoardPreference.cardFaceLayout` replaces this.
  cardFaceLayout  String    @default("standard")
  /// null = inherit sub-board preference `completeCheckboxVisibleByDefault`.
  showCompleteCheckbox Boolean?
  comments     Comment[]
  checklist    ChecklistItem[]
  labels       TaskLabel[]
  userBrandTicketLabels TaskUserBrandTicketLabel[]
  activities   Activity[]
  assignmentEvents TicketAssignmentEvent[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([subBoardId])
  @@index([subBoardId, trackerStatus])
  @@index([subBoardId, trackerStatus, archivedAt])
  @@index([ideaNodeId])
  @@index([chatThreadId])
  @@index([assigneeUserId])
  @@index([createdByUserId])
}

/// Append-only record of assignee changes for tickets.
model TicketAssignmentEvent {
  id          String   @id @default(cuid())
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  fromUserId  String?
  toUserId    String?
  actorUserId String
  actorUser   AppUser  @relation(fields: [actorUserId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([taskId])
  @@index([actorUserId])
}

// --- Consulting chat + RAG ---

model ChatThread {
  id              String        @id @default(cuid())
  projectId       String
  project         Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  /// Optional default workspace for creating tasks from chat (TaskFoundry)
  workspaceId     String?
  workspace       Workspace?    @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  title           String        @default("New chat")
  consultingMode  String        @default("strategy")
  messages        ChatMessage[]
  documents       ChatDocument[]
  tasks           Task[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([projectId])
  @@index([workspaceId])
}

model ChatMessage {
  id         String     @id @default(cuid())
  threadId   String
  thread     ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  role       String
  content    String     @db.Text
  citations  Json?
  createdAt  DateTime   @default(now())

  @@index([threadId])
}

model ChatDocument {
  id            String          @id @default(cuid())
  projectId     String
  project       Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  threadId      String?
  thread        ChatThread?     @relation(fields: [threadId], references: [id], onDelete: SetNull)
  filename      String
  mime          String          @default("application/octet-stream")
  source        String          @default("upload")
  contentHash   String?
  status        String          @default("pending")
  extractedText String?         @db.Text
  chunks        DocumentChunk[]
  createdAt     DateTime        @default(now())

  @@index([projectId])
  @@index([threadId])
}

model DocumentChunk {
  id         String       @id @default(cuid())
  documentId String
  document   ChatDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  chunkIndex Int
  content    String       @db.Text
  embedding  Json
  createdAt  DateTime     @default(now())

  @@index([documentId])
}

model Label {
  id      String      @id @default(cuid())
  boardId String
  board   Board       @relation(fields: [boardId], references: [id], onDelete: Cascade)
  name    String
  color   String      @default("#6366f1")
  tasks   TaskLabel[]
  notes   NoteLabel[]

  @@index([boardId])
}

/// Personal ticket labels for one login within one brand (available on all boards in that brand).
model UserBrandTicketLabel {
  id        String   @id @default(cuid())
  userId    String
  user      AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  brandId   String
  brand     Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  name      String   @db.VarChar(128)
  color     String   @default("#6366f1") @db.VarChar(32)
  taskLinks TaskUserBrandTicketLabel[]
  noteLinks NoteUserBrandTicketLabel[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, brandId, name])
  @@index([brandId])
  @@index([userId, brandId])
}

model TaskUserBrandTicketLabel {
  taskId                 String
  userBrandTicketLabelId String
  task                   Task                 @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userBrandTicketLabel   UserBrandTicketLabel @relation(fields: [userBrandTicketLabelId], references: [id], onDelete: Cascade)

  @@id([taskId, userBrandTicketLabelId])
  @@index([userBrandTicketLabelId])
}

model TaskLabel {
  taskId  String
  labelId String
  task    Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label   Label  @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([taskId, labelId])
}

model NoteLabel {
  noteId  String
  labelId String
  note    Note   @relation(fields: [noteId], references: [id], onDelete: Cascade)
  label   Label  @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([noteId, labelId])
  @@index([labelId])
}

model NoteUserBrandTicketLabel {
  noteId                 String
  userBrandTicketLabelId String
  note                   Note                 @relation(fields: [noteId], references: [id], onDelete: Cascade)
  userBrandTicketLabel   UserBrandTicketLabel @relation(fields: [userBrandTicketLabelId], references: [id], onDelete: Cascade)

  @@id([noteId, userBrandTicketLabelId])
  @@index([userBrandTicketLabelId])
}

model Comment {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  body      String
  /// Set for new comments; null on rows created before author tracking.
  authorUserId String?
  author       AppUser? @relation("TaskCommentAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@index([taskId])
  @@index([authorUserId])
}

model ChecklistItem {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  title     String
  completed Boolean  @default(false)
  position  Int      @default(0)

  @@index([taskId])
}

model Activity {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  /// Who performed this action; null = legacy/system rows (shown as System in the Activity Tracker).
  actorUserId String?
  actorUser   AppUser? @relation("TaskActivityActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  action    String
  detail    String   @default("")
  createdAt DateTime @default(now())

  @@index([taskId])
  @@index([actorUserId])
}

# Database (PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/three_lions?schema=public"
# Vercel: add DATABASE_URL to Production (and Preview if you use DB there). During `vercel-build`, if DATABASE_URL is set,
# `prisma migrate deploy` runs so tables exist before traffic hits the API. Use sslmode / pooling params your host documents.

# Bootstrap accounts (server startup seed). Passwords are bcrypt-hashed in the database — only the values you set here
# are usable for sign-in. Never commit real `.env` files.
# SEED_ADMIN_PASSWORD=""
# SEED_JIMMY_PASSWORD=""

# API server
PORT=3001
# Comma-separated browser origins allowed for credentialed API calls (CORS).
# Local: Vite dev server. Vercel: list every browser origin that calls the API (https://www.example.com and
# https://example.com if you use both). VERCEL_URL / VERCEL_PROJECT_PRODUCTION_URL are merged automatically with www/apex variants.
CLIENT_ORIGIN="http://localhost:5173"

# Frontend (Vite): when the UI is hosted separately (e.g. Vercel static) and the API is on another
# origin, set this at **build** time to the public API base URL (no trailing slash). Leave unset for
# local dev (Vite proxies /api to PORT) or same-origin deployments.
# VITE_API_BASE_URL="https://api.yourdomain.com"

# Optional: reserved for future signed payloads / rotation (sessions are DB-backed today).
# SESSION_SECRET=""

# AI backend (server-side only; never expose to the browser)
# Selection: AI_PROVIDER=openai | ollama | groq (optional). If unset:
#   - Vercel (`VERCEL=1`) + GROQ_API_KEY → Groq for chat (recommended for hosted).
#   - Else production → OpenAI; else → Ollama (local).
# AI_PROVIDER=""

# Groq (OpenAI-compatible chat at https://api.groq.com/openai/v1). Used on Vercel when GROQ_API_KEY is set.
# Groq does not host embeddings: set OPENAI_API_KEY as well for RAG / document upload / semantic search.
# Put the real key only in `.env` (local) or Vercel Environment Variables (hosted)—never commit secrets here.
# GROQ_API_KEY=""
# GROQ_BASE_URL="https://api.groq.com/openai/v1"
# GROQ_CHAT_MODEL="llama-3.3-70b-versatile"
# GROQ_CHAT_MODEL_MINI="llama-3.1-8b-instant"
# GROQ_CHAT_MODEL_JSON="llama-3.1-8b-instant"

# OpenAI (chat when AI_PROVIDER=openai or production OpenAI path; embeddings whenever not using Ollama)
OPENAI_API_KEY=""

# Optional OpenAI model overrides (defaults: gpt-4.1, gpt-4.1-mini, gpt-4o-mini for JSON quick-capture, text-embedding-3-small)
# OPENAI_CHAT_MODEL=""
# OPENAI_CHAT_MODEL_MINI=""
# OPENAI_CHAT_MODEL_JSON=""
# OPENAI_EMBEDDING_MODEL=""

# Ollama (used when AI_PROVIDER is ollama, or in development by default)
# OLLAMA_HOST="http://127.0.0.1:11434"
# OLLAMA_CHAT_MODEL="llama3.2"
# OLLAMA_CHAT_MODEL_MINI=""
# OLLAMA_EMBEDDING_MODEL="nomic-embed-text"
# OLLAMA_API_KEY="ollama"

# Optional: index a server-local directory into chat RAG (self-hosted only; security-sensitive)
# ALLOW_LOCAL_PATH_INGEST=true
# LOCAL_INGEST_ROOT="/absolute/path/to/allowed/root"
# LOCAL_INGEST_MAX_FILES=40
